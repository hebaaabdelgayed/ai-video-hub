      {
        "type": "list",
        "items": [
          "\u062a\u0644\u062e\u064a\u0635 \u0627\u0644\u0645\u0642\u0627\u0644\u0627\u062a \u0627\u0644\u0637\u0648\u064a\u0644\u0629 \u0648\u0645\u0644\u0641\u0627\u062a PDF \u0642\u0628\u0644 \u0627\u0644\u0642\u0631\u0627\u0621\u0629 \u0627\u0644\u062a\u0641\u0635\u064a\u0644\u064a\u0629.",
          "\u0627\u0633\u062a\u062e\u0631\u0627\u062c \u0627\u0644\u0623\u0633\u0626\u0644\u0629 \u0627\u0644\u0628\u062d\u062b\u064a\u0629 \u0623\u0648 \u0627\u0644\u0646\u0642\u0627\u0637 \u0627\u0644\u0645\u062a\u0643\u0631\u0631\u0629 \u0628\u064a\u0646 \u0639\u062f\u0629 \u0645\u0635\u0627\u062f\u0631.",
